{
  "name": "self-profile-system",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "dev": "next dev -p 3000",
    "dev:clean": "npm run clean && next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint",
    "electron": "electron .",
    "desktop": "concurrently \"npm run dev\" \"wait-on http://localhost:3000/en && npm run electron\""
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "next": "^15.3.3",
    "next-intl": "^4.13.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
